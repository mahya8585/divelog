# Azure Cosmos DB 接続設定（オプション）
# 設定しない場合は workflow/json/ のJSONファイルを直接読み込みます

COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-primary-key>
COSMOS_DATABASE=divelog
COSMOS_CONTAINER=dives

# ── ログイン認証設定 ──────────────────────────────────────
# ユーザーのメールアドレスとパスワードを設定します。
# 未設定の場合は認証がスキップされます（開発環境向け）。
AUTH_EMAIL=your@email.com
AUTH_PASSWORD=your-password

# トークン署名用シークレットキー（設定しない場合は起動ごとにランダム生成）
# 本番環境では必ず固定値を設定してください。
SECRET_KEY=your-secret-key
