{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "lat": {
      "type": "number",
      "minimum": -90,
      "maximum": 90,
      "description": "緯度"
    },
    "lon": {
      "type": "number",
      "minimum": -180,
      "maximum": 180,
      "description": "経度"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "推定の自信度（0.0〜1.0）"
    },
    "source": {
      "type": "string",
      "enum": ["llm", "llm+rag"],
      "description": "推定根拠"
    },
    "place_canonical": {
      "type": "string",
      "description": "正規化したロケーション名"
    }
  },
  "required": ["lat", "lon", "confidence", "source", "place_canonical"]
}
