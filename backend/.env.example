# バックエンド環境変数設定例
# このファイルを .env としてコピーして使用してください

# Flask
FLASK_DEBUG=true
PORT=8000

# CORS: フロントエンドの URL（本番では具体的なURLを指定）
ALLOWED_ORIGINS=http://localhost:3000

# Azure Cosmos DB（オプション: 未設定時は workflow/json/ のJSONを使用）
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-primary-key>
COSMOS_DATABASE=divelog
COSMOS_CONTAINER=dives
COSMOS_ZXU_CONTAINER=zxu_uploads
COSMOS_LOCATION_KNOWLEDGE_CONTAINER=location_knowledge

# LLM（ロケーション提案生成用、未設定時は提案をスキップ）
LLM_API_KEY=<your-llm-api-key>
LLM_API_URL=https://api.openai.com/v1/chat/completions

# ユーザー管理用コンテナ（デフォルト: "users"）
COSMOS_USERS_CONTAINER=users
# トークン管理用コンテナ（デフォルト: "tokens"、TTL = 10 分）
COSMOS_TOKENS_CONTAINER=tokens

# ── ログイン認証設定 ──────────────────────────────────────
# Cosmos DB 設定時: 初回起動時に users コンテナにユーザーを自動作成
# Cosmos DB 未設定時: 環境変数で直接認証（ローカル開発向けフォールバック）
AUTH_EMAIL=your@email.com
AUTH_PASSWORD=your-password

# トークン署名用シークレットキー（Cosmos DB 未使用時のフォールバック用）
SECRET_KEY=your-secret-key

# ── Application Insights 設定 ──────────────────────────
# Azure Monitor Application Insights の接続文字列（オプション）
# 設定するとWARNING/ERRORログが Application Insights へ転送されます
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
