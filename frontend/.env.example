# フロントエンド環境変数設定例
# このファイルを .env.local としてコピーして使用してください

# バックエンド API の URL
# 開発時: vite.config.js のプロキシを使うため不要（空にしておく）
# 本番時: Azure Container Apps のエンドポイントを設定
VITE_API_BASE_URL=https://<your-container-apps-name>.<region>.azurecontainerapps.io

# ── Application Insights 設定 ──────────────────────────
# Azure Monitor Application Insights の接続文字列（オプション）
# 設定すると未処理例外・WARNING イベントが Application Insights へ転送されます
VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
