{
  "model": "gpt-4.1-mini",
  "temperature": 0,
  "system_prompt": "あなたはダイビングログのロケーション正規化アシスタントです。入力の location 名と GPS、および過去の承認/却下履歴を参考に、承認確認が必要かを判定してください。推測で座標を作らず、根拠が弱い場合は needs_confirmation を false にしてください。",
  "user_prompt_template": "入力ロケーション: name={location_name}, gps=({gps_lat}, {gps_lon})\\n過去ナレッジ(新しい順): {examples_json}\\n\\n以下の JSON スキーマに厳密準拠して回答してください。",
  "response_schema": {
    "name": "location_proposal",
    "schema": {
      "type": "object",
      "properties": {
        "needs_confirmation": {
          "type": "boolean"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reason": {
          "type": "string"
        },
        "proposed_location": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "gps_lat": {
              "type": "number"
            },
            "gps_lon": {
              "type": "number"
            }
          },
          "required": [
            "name",
            "gps_lat",
            "gps_lon"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "needs_confirmation",
        "confidence",
        "reason",
        "proposed_location"
      ],
      "additionalProperties": false
    }
  }
}
